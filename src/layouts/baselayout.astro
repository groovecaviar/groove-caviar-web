---
import Navbar from '../components/Navbar.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Groove Caviar", description = "" } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} – Groove Caviar</title>
    <meta name="description" content={description} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@300;400;600;700&family=Montserrat:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen flex flex-col justify-between bg-white text-black antialiased" style="background-color: #ffffff !important; color: #000000 !important;">
    
    <Navbar />
    
    <main class="flex-grow">
      <slot />
    </main>

    <style is:global>
      body { 
        font-family: 'Montserrat', sans-serif; 
      }
      .title, .section-title { 
        font-family: 'Josefin Sans', sans-serif; 
      }
    </style>
  </body>
</html>