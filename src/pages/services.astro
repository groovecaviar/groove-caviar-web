---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

// Astro a besoin de savoir quelles versions générer
export function getStaticPaths() {
  return [
    { params: { lang: undefined } }, // Français par défaut (ex: /services)
    { params: { lang: 'en' } },      // Anglais (ex: /en/services)
  ];
}

const { lang = 'fr' } = Astro.params;
const t = useTranslations(lang as 'fr' | 'en');
---

<BaseLayout title={t('services.title')} description={t('services.p1')}>
  <main class="max-w-7xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    
    <div>
      <img 
        src="/images/SERVICES-prestation-dj.webp" 
        alt="Groove Caviar Prestation DJ" 
        class="w-full h-auto object-cover rounded shadow-lg"
      />
    </div>

    <div class="space-y-6">
      <span class="text-xs uppercase tracking-widest text-neutral-500 font-medium block">
        {t('services.label')}
      </span>
      
      <h1 class="text-4xl font-bold text-black uppercase tracking-tight">
        {t('services.title')}
      </h1>
      
      <h2 class="text-xs italic uppercase tracking-wider text-neutral-400">
        {t('services.subtitle')}
      </h2>

      <p class="text-neutral-700 leading-relaxed text-justify">
        {t('services.p1')}
      </p>

      <p class="text-neutral-700 leading-relaxed text-justify">
        {t('services.p2')}
      </p>

      <p class="text-neutral-700 leading-relaxed text-justify">
        <strong>{t('services.p3_title')}</strong>{t('services.p3_text')}
      </p>

      <div class="pt-4">
        <a href="#contact" class="inline-block border-b-2 border-[#AF9453] pb-1 text-xs font-bold uppercase tracking-wider hover:text-[#AF9453] transition-colors">
          {t('services.cta')} &rarr;
        </a>
      </div>
    </div>

  </main>
</BaseLayout>