---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'en' } },
  ];
}

const { lang = 'fr' } = Astro.params;
const t = useTranslations(lang as 'fr' | 'en');
---

<BaseLayout title={t('services.hero_title')} description={t('services.s1_p1')}>
  
  <div class="relative w-full h-[40vh] bg-neutral-900 flex flex-col items-center justify-center text-center px-4">
    <div class="absolute inset-0 bg-black/40 z-0"></div>
    <div class="relative z-10 space-y-2">
      <span class="text-neutral-400 text-xs font-bold tracking-[0.2em] uppercase block">{t('services.hero_label')}</span>
      <h1 class="font-title font-bold text-4xl sm:text-6xl text-white tracking-[0.05em] uppercase">
        NOS <span class="text-gold italic font-serif lowercase">services</span>
      </h1>
    </div>
  </div>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 space-y-32">
    
    <section class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <img src="/images/SERVICES-prestation-dj.webp" alt="Prestation DJ" class="w-full h-auto object-cover rounded bg-neutral-100" />
      </div>
      <div class="space-y-4">
        <span class="text-xs font-semibold text-gold tracking-widest block uppercase">{t('services.s1_label')}</span>
        <h2 class="font-title font-bold text-3xl text-neutral-900 uppercase tracking-wide">{t('services.s1_title')}</h2>
        <h3 class="text-sm font-medium tracking-widest text-neutral-500 uppercase">{t('services.s1_subtitle')}</h3>
        <p class="text-neutral-700 leading-relaxed text-justify font-sans">{t('services.s1_p1')}</p>
        <p class="text-neutral-700 leading-relaxed text-justify font-sans">{t('services.s1_p2')}</p>
        <p class="text-neutral-700 leading-relaxed text-justify font-sans">
          <strong class="text-neutral-900 font-bold">{t('services.s1_p3_title')}</strong>{t('services.s1_p3_text')}
        </p>
        <div class="pt-4">
          <a href="#contact" class="inline-block border-b border-neutral-900 pb-1 text-xs font-bold uppercase tracking-wider hover:text-gold hover:border-gold transition-colors">
            {t('services.s1_cta')} &rarr;
          </a>
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="space-y-4 md:order-1 order-2">
        <span class="text-xs font-semibold text-gold tracking-widest block uppercase">{t('services.s2_label')}</span>
        <h2 class="font-title font-bold text-3xl text-neutral-900 uppercase tracking-wide">{t('services.s2_title')}</h2>
        <h3 class="text-sm font-medium tracking-widest text-neutral-500 uppercase">{t('services.s2_subtitle')}</h3>
        <p class="text-neutral-700 leading-relaxed text-justify font-sans">{t('services.s2_p1')}</p>
        
        <ul class="space-y-2 text-sm text-neutral-700 pl-4 list-none font-sans">
          <li class="flex items-start"><span class="text-gold mr-2">▶</span> {t('services.s2_b1')}</li>
          <li class="flex items-start"><span class="text-gold mr-2">▶</span> {t('services.s2_b2')}</li>
          <li class="flex items-start"><span class="text-gold mr-2">▶</span> {t('services.s2_b3')}</li>
          <li class="flex items-start"><span class="text-gold mr-2">▶</span> {t('services.s2_b4')}</li>
        </ul>

        <p class="text-neutral-700 leading-relaxed text-justify font-sans pt-2">
          <strong class="text-neutral-900 font-bold">Rythme, sobriété et charisme :</strong> Nos speakers agissent avec charisme mais surtout avec sobriété, évitant les clichés de l'animation traditionnelle pour se concentrer sur l'essentiel.
        </p>
        <div class="pt-4">
          <a href="#contact" class="inline-block border-b border-neutral-900 pb-1 text-xs font-bold uppercase tracking-wider hover:text-gold hover:border-gold transition-colors">
            {t('services.s2_cta')} &rarr;
          </a>
        </div>
      </div>
      <div class="md:order-2 order-1">
        <img src="/images/SERVICES-prestation-speaker.webp" alt="Prestation Speaker MC" class="w-full h-auto object-cover rounded bg-neutral-100" />
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <img src="/images/SERVICES-sonorisation.webp" alt="Sonorisation et Éclairage" class="w-full h-auto object-cover rounded bg-neutral-100" />
      </div>
      <div class="space-y-4">
        <span class="text-xs font-semibold text-gold tracking-widest block uppercase">{t('services.s3_label')}</span>
        <h2 class="font-title font-bold text-3xl text-neutral-900 uppercase tracking-wide">{t('services.s3_title')}</h2>
        <h3 class="text-sm font-medium tracking-widest text-neutral-500 uppercase">{t('services.s3_subtitle')}</h3>
        <p class="text-neutral-700 leading-relaxed text-justify font-sans">{t('services.s3_p1')}</p>
        <p class="text-neutral-700 leading-relaxed text-justify font-sans">{t('services.s3_p2')}</p>
        
        <div class="border border-neutral-200 p-4 bg-neutral-50 rounded text-sm italic text-neutral-600 font-sans text-justify">
          {t('services.s3_callout')}
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="space-y-4 md:order-1 order-2">
        <span class="text-xs font-semibold text-gold tracking-widest block uppercase">{t('services.s4_label')}</span>
        <h2 class="font-title font-bold text-3xl text-neutral-900 uppercase tracking-wide">{t('services.s4_title')}</h2>
        <h3 class="text-sm font-serif italic text-neutral-700 tracking-wide">{t('services.s4_subtitle')}</h3>
        <p class="text-neutral-700 leading-relaxed text-justify font-sans pt-2">{t('services.s4_p1')}</p>
        <p class="text-neutral-700 leading-relaxed text-justify font-sans">{t('services.s4_p2')}</p>
        <div class="pt-4">
          <a href="#contact" class="inline-block border-b border-neutral-900 pb-1 text-xs font-bold uppercase tracking-wider hover:text-gold hover:border-gold transition-colors">
            {t('services.s4_cta')} &rarr;
          </a>
        </div>
      </div>
      <div class="md:order-2 order-1">
        <img src="/images/SERVICES-design-sonore.webp" alt="Design Sonore" class="w-full h-auto object-cover rounded bg-neutral-100" />
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <img src="/images/SERVICES-prod-event.webp" alt="Production Événementielle" class="w-full h-auto object-cover rounded bg-neutral-100" />
      </div>
      <div class="space-y-4">
        <span class="text-xs font-semibold text-gold tracking-widest block uppercase">{t('services.s5_label')}</span>
        <h2 class="font-title font-bold text-3xl text-neutral-900 uppercase tracking-wide">{t('services.s5_title')}</h2>
        <h3 class="text-sm font-medium tracking-widest text-neutral-500 uppercase">{t('services.s5_subtitle')}</h3>
        <p class="text-neutral-700 leading-relaxed text-justify font-sans">{t('services.s5_p1')}</p>
        <p class="text-neutral-700 leading-relaxed text-justify font-sans">{t('services.s5_p2')}</p>
        <div class="pt-4">
          <a href="#contact" class="inline-block border-b border-neutral-900 pb-1 text-xs font-bold uppercase tracking-wider hover:text-gold hover:border-gold transition-colors">
            {t('services.s5_cta')} &rarr;
          </a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>