---
// src/components/Navbar.astro
---
<header class="w-full bg-black text-white z-50 sticky top-0 border-b border-neutral-900/50" style="background-color: #0a0a0a !important; font-family: 'Montserrat', sans-serif;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-24 flex items-center justify-between">
    
    <a href="/" class="flex items-center gap-3.5 group">
      <img src="/assets/logo-circulaire.webp" alt="Groove Caviar" class="w-10 h-10 object-contain" />
      <span class="text-xl font-bold tracking-[0.15em] text-[#AF9453] uppercase" style="font-family: 'Josefin Sans', sans-serif;">
        GROOVE CAVIAR
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-7 text-[11px] font-bold tracking-[0.2em] uppercase">
      <a href="/" class="text-neutral-400 hover:text-white transition-colors duration-300">HOME</a>
      <a href="/services" class="text-[#AF9453] border-b-2 border-[#AF9453] pb-1">SERVICES</a>
      <a href="/musique" class="text-neutral-400 hover:text-white transition-colors duration-300">MUSIQUE</a>
      <a href="/dj-soirees" class="text-neutral-400 hover:text-white transition-colors duration-300">DJ SOIRÉES</a>
      <a href="/faq" class="text-neutral-400 hover:text-white transition-colors duration-300">FAQ</a>
      <a href="/contact" class="text-neutral-400 hover:text-white transition-colors duration-300">CONTACT</a>
    </nav>

    <div class="hidden sm:block">
      <a href="tel:+33000000000" class="inline-block text-[11px] tracking-[0.15em] uppercase font-bold text-black px-6 py-3 transition-all duration-300 hover:bg-white hover:text-black" style="background-color: #AF9453 !important; color: #000000 !important; border-radius: 6px !important;">
        APPELEZ-NOUS !
      </a>
    </div>

  </div>
</header>