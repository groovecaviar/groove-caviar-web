---
import { useTranslations } from '../i18n/utils';

// 1. Détection de la langue actuelle
const lang = (Astro.currentLocale as 'fr' | 'en') || 'fr';
const t = useTranslations(lang);
const pathname = Astro.url.pathname;

// 2. Configuration des liens de navigation (Centralisé et propre)
const navItems = [
  { labelFr: 'Accueil', labelEn: 'Home', path: '/' },
  { labelFr: 'Nos Services', labelEn: 'Services', path: '/services' },
  { labelFr: 'Mixes & Univers', labelEn: 'Music & Mixes', path: '/musique' },
  { labelFr: 'FAQ', labelEn: 'FAQ', path: '/faq' },
  { labelFr: 'Contact', labelEn: 'Contact', path: '/contact' }
];

// 3. Logique dynamique pour calculer les destinations de bascule des drapeaux
let cleanPath = pathname;
if (pathname.startsWith('/en')) {
  cleanPath = pathname.replace(/^\/en/, '');
}
if (cleanPath === '') cleanPath = '/';

const frUrl = cleanPath;
const enUrl = cleanPath === '/' ? '/en' : `/en${cleanPath}`;
---

<header class="w-full bg-white border-b border-neutral-100 sticky top-0 z-50 font-sans backdrop-blur-md bg-white/90">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
    
    <a href={lang === 'fr' ? '/' : '/en'} class="flex items-center space-x-2 group">
      <span class="font-title font-bold text-xl tracking-[0.15em] text-neutral-900 transition-colors group-hover:text-neutral-700">
        GROOVE <span class="text-gold">CAVIAR</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center space-x-8 text-[11px] font-bold tracking-[0.2em] uppercase">
      {navItems.map((item) => {
        // Résolution dynamique de l'URL selon la langue
        const targetUrl = lang === 'fr' ? item.path : (item.path === '/' ? '/en' : `/en${item.path}`);
        
        // Vérification précise si l'onglet courant est actif
        const isActive = pathname === targetUrl || (item.path !== '/' && pathname.includes(item.path));
        
        return (
          <a 
            href={targetUrl} 
            class={`transition-colors duration-300 ${isActive ? 'text-gold' : 'text-neutral-800 hover:text-gold'}`}
          >
            {lang === 'fr' ? item.labelFr : item.labelEn}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center">
      
      <a href="tel:+33623625704" class="btn-nav hidden sm:inline-flex whitespace-nowrap">
        {lang === 'fr' ? 'Appelez-nous !' : 'Call us !'}
      </a>

      <div class="flex items-center space-x-3 ml-4 border-l border-neutral-200 pl-4">
        
        <a href={frUrl} title="Version Française" class="transition-transform hover:scale-110 block">
          <img 
            src="/assets/FR-flag.svg" 
            alt="Français" 
            class={`w-5 h-3.5 object-cover rounded-sm shadow-sm transition-all duration-300 ${lang === 'fr' ? 'grayscale-0 opacity-100' : 'grayscale opacity-35 hover:opacity-80'}`}
          />
        </a>

        <a href={enUrl} title="English Version" class="transition-transform hover:scale-110 block">
          <img 
            src="/assets/EN-flag.svg" 
            alt="English" 
            class={`w-5 h-3.5 object-cover rounded-sm shadow-sm transition-all duration-300 ${lang === 'en' ? 'grayscale-0 opacity-100' : 'grayscale opacity-35 hover:opacity-80'}`}
          />
        </a>

      </div>
    </div>

  </div>
</header>