---
// src/components/Navbar.astro
---
<header class="w-full bg-black text-white z-50 sticky top-0 h-20 flex items-center border-b border-neutral-900/40" style="background-color: #000000 !important;">
  <div class="max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 flex items-center justify-between">
    
    <a href="/" class="flex items-center gap-3">
      <img src="/assets/logo-circulaire.webp" alt="Logo Groove Caviar" class="h-10 w-10 object-contain" />
      <span class="text-2xl font-bold tracking-[0.08em] text-[#AF9453] uppercase" style="font-family: 'Josefin Sans', sans-serif;">
        GROOVE CAVIAR
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-7 text-[13px] font-bold tracking-[0.2em] uppercase" style="font-family: 'Montserrat', sans-serif;">
      <a href="/" class="text-neutral-400 hover:text-white transition-colors duration-300 py-1">HOME</a>
      <a href="/services" class="text-white border-b-2 border-[#AF9453] pb-1">SERVICES</a>
      <a href="/musique" class="text-neutral-400 hover:text-white transition-colors duration-300 py-1">MUSIQUE</a>
      <a href="/dj-soirees" class="text-neutral-400 hover:text-white transition-colors duration-300 py-1">DJ SOIRÉES</a>
      <a href="/faq" class="text-neutral-400 hover:text-white transition-colors duration-300 py-1">FAQ</a>
      <a href="/contact" class="text-neutral-400 hover:text-white transition-colors duration-300 py-1">CONTACT</a>
    </nav>

    <div class="hidden sm:block">
      <a href="tel:+33000000000" class="inline-block text-[11px] tracking-[0.2em] uppercase font-bold bg-[#AF9453] text-black px-6 py-2.5 rounded-md hover:bg-white hover:text-black transition-all duration-300" style="background-color: #AF9453 !important; color: #000000 !important;">
        APPELEZ-NOUS !
      </a>
    </div>

  </div>
</header>