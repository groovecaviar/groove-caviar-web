---
// src/components/Navbar.astro
---
<header class="w-full sticky top-0 z-50 bg-black/95 backdrop-blur-xl border-b border-white/[0.06]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-[76px] flex justify-between items-center">
      
      <a href="/" class="flex items-center space-x-3 group">
          <img src="/assets/logo-circulaire.webp" alt="Logo Groove Caviar" class="w-[38px] h-[38px] object-contain transition-transform duration-500 group-hover:scale-105">
          <span class="text-xl sm:text-2xl font-bold tracking-[0.02em] uppercase text-[#AF9453] align-middle" style="font-family: 'Josefin Sans', sans-serif;">Groove Caviar</span>
      </a>
      
      <nav class="hidden lg:flex items-center space-x-8 text-[12px] tracking-[0.2em] uppercase font-semibold text-gray-400 h-full" style="font-family: 'Montserrat', sans-serif;">
          <a href="/" class="hover:text-white transition-colors duration-300">Home</a>
          <a href="/services" class="text-white font-bold border-b-2 border-[#AF9453] pb-1">Services</a>
          <a href="/musique" class="hover:text-white transition-colors duration-300">Musique</a>
          <a href="/dj-soirees" class="hover:text-white transition-colors duration-300">DJ Soirées</a>
          <a href="/faq" class="hover:text-white transition-colors duration-300">FAQ</a>
          <a href="/contact" class="hover:text-white transition-colors duration-300">Contact</a>
      </nav>

      <div class="flex items-center">
          <a href="tel:+33623625704" class="inline-flex items-center justify-center h-[38px] text-[11px] tracking-[0.2em] uppercase font-bold bg-[#AF9453] text-black px-6 rounded-md shadow-lg transform hover:scale-105 hover:bg-white hover:text-black hover:shadow-[0_0_25px_rgba(175,148,83,0.45)] transition-all duration-300 ease-out">
              Appelez-nous !
          </a>
      </div>
  </div>
</header>