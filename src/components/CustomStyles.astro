---
import '@fontsource-variable/inter'; // corps de texte (lisibilité)
import '@fontsource-variable/josefin-sans'; // titres / logo
import '@fontsource/rock-salt'; // citations uniquement (décoratif)
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Josefin Sans Variable';

    /* Palette Groove Caviar — or & noir */
    --aw-color-primary: rgb(175 148 83); /* #AF9453 */
    --aw-color-secondary: rgb(138 116 64); /* #8A7440 (hover) */
    --aw-color-accent: rgb(202 172 102); /* #CAAC66 */

    --aw-color-text-heading: rgb(13 13 13); /* #0D0D0D */
    --aw-color-text-default: rgb(26 26 26);
    --aw-color-text-muted: rgb(13 13 13 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(13 13 13); /* #0D0D0D sections sombres */

    ::selection {
      background-color: rgb(175 148 83 / 30%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Josefin Sans Variable';

    --aw-color-primary: rgb(202 172 102); /* or plus clair sur fond sombre */
    --aw-color-secondary: rgb(175 148 83);
    --aw-color-accent: rgb(226 209 164); /* #E2D1A4 */

    --aw-color-text-heading: rgb(247 248 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(13 13 13);

    ::selection {
      background-color: rgb(175 148 83 / 40%);
      color: snow;
    }
  }
</style>
