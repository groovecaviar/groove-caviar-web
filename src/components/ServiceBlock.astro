---
import SectionHeader from './SectionHeader.astro';

interface Props {
  label: string;
  title: string;
  subtitle?: string;
  imgSrc: string;
  imgAlt: string;
  isReversed?: boolean;
  linkHref?: string;
  linkText?: string;
  serifQuote?: string;
  callout?: string;
}

const { 
  label, 
  title, 
  subtitle, 
  imgSrc, 
  imgAlt, 
  isReversed = false, 
  linkHref, 
  linkText,
  serifQuote,
  callout
} = Astro.props;
---

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 scroll-reveal">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <div class={`lg:col-span-6 ${isReversed ? 'lg:order-2' : ''} card-image-wrapper`}>
          <img src={imgSrc} alt={imgAlt} class="card-image">
      </div>
      <div class={`lg:col-span-6 space-y-6 ${isReversed ? 'lg:order-1 lg:pr-6' : 'lg:pl-6'}`}>
          <SectionHeader label={label} title={title} subtitle={subtitle} />
          
          {serifQuote && (
            <div class="serif-title">
              {serifQuote}
            </div>
          )}

          <div class="section-body">
              <slot />
          </div>

          {callout && (
            <div class="callout-box">
              {callout}
            </div>
          )}

          {linkHref && linkText && (
            <div class="pt-4">
                <a href={linkHref} class="text-link">{linkText} &rarr;</a>
            </div>
          )}
      </div>
  </div>
</section>